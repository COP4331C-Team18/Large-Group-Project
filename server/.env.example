# Server
PORT= // port number (ex: 3000)

# Database
MONGODB_URI= // paste connection string here

# Auth
JWT_SECRET= // any random string really 

# Email (Nodemailer)
EMAIL_USER= // your email address here 
EMAIL_PASS= // gmail app password here (not your google acc password )
            // it should be a 16 character password generated from your google account security settings
            // should look something like: abcd efgh ijkl mnop

// For password hashing
BCRYPT_SALT_ROUNDS= // some number (ex: 10)

// For Google OAuth
GOOGLE_CLIENT_ID= // your Google OAuth client ID here 