{
    "server": {
        "port": 9001,
        "host": "0.0.0.0",
        "max_connections": 1000,
        "idle_timeout": 120
    },
    "ssl": {
        "enabled": false,
        "cert": "/opt/inksubserver/certs/cert.pem",
        "key": "/opt/inksubserver/certs/key.pem"
    },
    "node_api": {
        "url": "http://localhost:5001/api",
        "internal_secret": "REPLACE_WITH_VALUE_FROM_SERVER_ENV_INTERNAL_SECRET"
    },
    "logging": {
        "level": "info",
        "file": "/opt/inksubserver/logs/server.log"
    },
    "env": "development"
}
