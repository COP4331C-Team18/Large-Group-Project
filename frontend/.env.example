VITE_GOOGLE_CLIENT_ID= // your Google OAuth client ID here (SAME AS IN SERVER/.ENV)
VITE_API_BASE_URL=http://localhost:5001/api
# WebSocket URL for inksubserver:
#   dev  → ws://localhost:9001
#   prod → wss://your-domain.com (when SSL is enabled in inksubserver config.json)
VITE_WS_URL=ws://localhost:9001